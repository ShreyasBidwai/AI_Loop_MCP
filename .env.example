# Governor caps (the seatbelt for a no-developer loop)
MAX_TURNS=40
MAX_EST_TOKENS=400000
STALL_LIMIT=6            # flat passing-count turns before "stuck" escalation

# Pacing: per-action throttle (seconds) — keeps cadence watchable + under rate walls
PACING_SECONDS=6

# Dashboard
DASHBOARD_PORT=3000

# Classifier / criteria LLM drafting (optional). When unset, falls back to the
# deterministic keyword/template stubs so the pipeline still runs with zero deps.
# ANTHROPIC_API_KEY=sk-ant-...
# LOOPING_MODEL=claude-opus-4-8
